---
type Props = {
  company: string;
  title: string;
  duration: string;
  location: string;
  bullets: string[];
};

const { company, title, duration, location, bullets } = Astro.props;
---

<article class="group relative rounded-3xl border border-ink/10 bg-paper p-6 shadow-soft transition hover:translate-y-[-2px] hover:shadow-[0_18px_60px_rgba(11,15,26,0.10)] sm:p-8">
  <div class="flex flex-col gap-6 md:flex-row md:items-start md:justify-between">
    <div>
      <h3 class="font-display text-3xl tracking-tightish">{company}</h3>
      <p class="mt-2 text-sm font-medium text-ink/70">{title}</p>
    </div>

    <div class="text-sm text-ink/65">
      <div class="inline-flex items-center gap-2 rounded-full border border-ink/10 bg-white/60 px-4 py-2">
        <span>{duration}</span>
        <span class="text-ink/30">•</span>
        <span>{location}</span>
      </div>
    </div>
  </div>

  <ul class="mt-6 space-y-3 text-sm leading-relaxed text-ink/75">
    {bullets.map((b) => (
      <li class="flex gap-3">
        <span class="mt-[0.45rem] h-1.5 w-1.5 flex-none rounded-full bg-accent/70"></span>
        <span>{b}</span>
      </li>
    ))}
  </ul>

  <div class="pointer-events-none absolute -right-14 -top-14 h-44 w-44 rounded-full bg-accent/8 blur-2xl opacity-0 transition group-hover:opacity-100"></div>
</article>

