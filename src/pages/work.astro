---
import BaseLayout from "../layouts/BaseLayout.astro";
import WorkCard from "../components/WorkCard.astro";

const base = import.meta.env.BASE_URL ?? "/";

const roles = [
  {
    company: "Scaler (InterviewBit)",
    title: "Product Manager ||",
    duration: "Mar 25 - Feb 25",
    location: "Bengaluru, India",
    bullets: [
      "Led the sales product line for improving sales productivity. Learned about AI. Got better at stakeholder management. Failed a lot. Learned a lot.",
      "Led the learning suite of products. Learned to navigate different stakeholders with competing priorities. Got better at product thinking and making decisions."
    ]
  },
  {
    company: "Mastercard",
    title: "Product Manager",
    duration: "Jul 22 - Feb 25",
    location: "Pune, India",
    bullets: [
      "Launched a multi-million dollar product. Got better at corporate speak. Found myself in comfort zone.",
    ]
  },
  {
    company: "Vedantu",
    title: "Intern, CEO's Office",
    duration: "Jun 21 - Aug 21",
    location: "Remote",
    bullets: [
      "Got my first exposure to corporate. Worked on multiple things like an enthu-cutlet. Pivoted my career from research to corporate."
    ]
  }
];
---

<BaseLayout title="Work Experience — Pratham Shukla" description="[PLACEHOLDER — work page description for SEO]">
  <section class="mx-auto max-w-6xl px-5 py-16">
    <header class="reveal">
      <p class="text-xs font-semibold tracking-wide text-ink/55">[PLACEHOLDER — section label]</p>
      <h1 class="mt-4 font-display text-5xl leading-[0.95] tracking-tightish sm:text-6xl">Work</h1>
      <p class="mt-5 max-w-2xl text-base leading-relaxed text-ink/70 sm:text-lg">
        I've tried to do it all — 0→1 builds, global products, big corporates, small startups.
        Not because I couldn't pick a lane, but because I genuinely wanted to know what each one felt like.
        Still figuring out which one I love most.
      </p>
    </header>

    <div class="mt-12 grid gap-6">
      {roles.map((r) => (
        <div class="reveal">
          <WorkCard {...r} />
        </div>
      ))}
    </div>

    <div class="mt-14 rounded-3xl border border-ink/10 bg-white/60 p-7 shadow-soft reveal">
      <div class="flex flex-col gap-4 md:flex-row md:items-center md:justify-between">
        <div>
          <h2 class="font-display text-3xl tracking-tightish">Want to work together?</h2>
          <p class="mt-2 text-sm leading-relaxed text-ink/70">
            Open to part-time/full-time gigs in product management and strategy.
          </p>
        </div>
        <a
          href={`${base}#contact`}
          class="inline-flex w-fit items-center justify-center rounded-full bg-accent px-6 py-3 text-sm font-semibold text-white shadow-soft hover:translate-y-[-1px] hover:shadow-[0_18px_52px_rgba(11,27,58,0.18)] transition"
        >
          Get in touch
        </a>
      </div>
    </div>
  </section>
</BaseLayout>

